NODE_ENV=development
PORT=3001
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/clickflow?schema=public
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=604800
PASSWORD_RESET_EXPIRES_IN_SECONDS=1800
EMAIL_VERIFICATION_EXPIRES_IN_SECONDS=86400
API_RATE_LIMIT=300
API_RATE_WINDOW_MS=60000
AUTH_RATE_LIMIT=5
AUTH_RATE_WINDOW_MS=900000
CORS_ORIGIN=http://localhost:3000
QUERY_TIMEOUT_MS=10000
# local/test: memory, production: r2
STORAGE_PROVIDER=memory
STORAGE_BUCKET=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
SEED_USER_EMAIL=demo@clickflow.local
SEED_USER_PASSWORD_HASH=

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=ClickFlow <no-reply@clickflow.local>

# Cloudinary legacy/optional
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
