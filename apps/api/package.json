{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "openapi:generate": "pnpm build && node dist/src/openapi/export-openapi.js",
    "openapi:check": "pnpm build && node dist/src/openapi/export-openapi.js --check",
    "smoke": "node scripts/smoke.mjs",
    "cleanup:attachments": "tsx src/attachments/cleanup-orphans.ts",
    "test:database": "vitest run --config vitest.database.config.ts"
  },
  "dependencies": {
    "@clickflow/contracts": "workspace:*",
    "@nestjs/common": "11.1.6",
    "@nestjs/core": "11.1.6",
    "@nestjs/platform-express": "11.1.6",
    "@nestjs/swagger": "11.2.0",
    "@prisma/client": "6.19.1",
    "argon2": "0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cloudinary": "^2.10.0",
    "dotenv": "17.4.2",
    "express": "5.1.0",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.1.0",
    "nodemailer": "^9.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "7.8.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@nestjs/cli": "11.0.10",
    "@nestjs/testing": "11.1.6",
    "@types/express": "^5.0.3",
    "@types/node": "^22.18.0",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "8.41.0",
    "@typescript-eslint/parser": "8.41.0",
    "eslint": "^9.34.0",
    "globals": "^16.3.0",
    "prisma": "6.19.1",
    "supertest": "^7.1.4",
    "tsx": "4.20.6",
    "typescript": "^5.9.2",
    "typescript-eslint": "8.41.0",
    "vite": "6.4.3",
    "vitest": "3.2.7"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
